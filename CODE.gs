function uploadPhotoToDrive(base64Data, fileName, rowIdx) {
  var mimeType = "image/jpeg";
  if (fileName && fileName.toLowerCase().indexOf(".png") !== -1) mimeType = "image/png";
  if (!fileName) fileName = "foto_" + Date.now() + ".jpg";

  var token = ScriptApp.getOAuthToken();
  var BOUNDARY = "boundary_" + Date.now();
  var CRLF = "\r\n";

  // Bangun multipart body dengan cara yang clean
  var metaJson = JSON.stringify({ name: fileName, parents: ["root"] });

  // Part 1 header (JSON)
  var part1 = "--" + BOUNDARY + CRLF
    + "Content-Type: application/json; charset=UTF-8" + CRLF + CRLF
    + metaJson + CRLF
    + "--" + BOUNDARY + CRLF
    + "Content-Type: " + mimeType + CRLF + CRLF;

  // Part 2 header + binary image data + closing boundary
  var imgBytes = Utilities.base64Decode(base64Data);
  var endPart = CRLF + "--" + BOUNDARY + "--" + CRLF;

  // Convert string parts ke bytes
  var part1Bytes = Utilities.newBlob(part1).getBytes();
  var endBytes = Utilities.newBlob(endPart).getBytes();

  // Gabung: part1_bytes + img_bytes + end_bytes
  var bodyBytes = part1Bytes.concat(imgBytes).concat(endBytes);

  var uploadUrl = "https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart&supportsAllDrives=true";
  var response;
  try {
    response = UrlFetchApp.fetch(uploadUrl, {
      method: "POST",
      headers: {
        Authorization: "Bearer " + token,
        "Content-Type": "multipart/related; boundary=" + BOUNDARY
      },
      payload: bodyBytes,
      muteHttpExceptions: true
    });
  } catch (e) {
    return { success: false, error: e.message };
  }

  var result = JSON.parse(response.getContentText());
  if (result.error || !result.id) {
    return { success: false, error: (result.error && result.error.message) || "Upload gagal" };
  }

  var newUrl = "https://drive.google.com/file/d/" + result.id + "/view?usp=drivesdk";

  // Update cell H di spreadsheet
  try {
    var ss2 = SpreadsheetApp.openById(CONFIG.SS_RESP_ID);
    var sheet2 = ss2.getSheetByName(CONFIG.SHEET_RESPONSES);
    var rowData = sheet2.getRange(rowIdx, 1, 1, sheet2.getLastColumn()).getValues()[0];
    var cellValue = String(rowData[7] || "").trim();
    if (cellValue.length > 0) {
      sheet2.getRange(rowIdx, 8).setValue(cellValue + ", " + newUrl);
    } else {
      sheet2.getRange(rowIdx, 8).setValue(newUrl);
    }
  } catch (sheetErr) {
    console.log("uploadPhotoToDrive gagal update cell: " + sheetErr.message);
  }

  return { success: true, fileId: result.id, url: newUrl };
}

