function createF4Doc(name) {
  var doc = DocumentApp.create(name);
  if (!doc) throw new Error("Gagal membuat dokumen: " + name);
  var body = doc.getBody();
  body.setPageWidth(612);
  body.setPageHeight(936);
  body.setMarginTop(40);
  body.setMarginBottom(40);
  body.setMarginLeft(40);
  body.setMarginRight(40);
  return doc;
}

function initDokumentasiDoc(repInfo) {
  try {
    var doc = createF4Doc("Temp_Dok_" + Date.now());
    doc.saveAndClose();
    return { success: true, docId: doc.getId() };
  } catch (e) { return { success: false, error: e.message }; }
}

function appendDokumentasiPhotos(docId, photoBatch, sectionInfo) {
  try {
    var doc = DocumentApp.openById(docId);
    var body = doc.getBody();
    if (sectionInfo) {
      var headerPara = body.appendParagraph("FOTO DOKUMENTASI");
      headerPara.setHeading(DocumentApp.ParagraphHeading.HEADING1);
      headerPara.setAlignment(DocumentApp.HorizontalAlignment.CENTER);
      headerPara.editAsText().setBold(true).setFontFamily("Arial");
      body.appendParagraph("");
      var tglInfo = new Date(sectionInfo.tanggal);
      var thn = isNaN(tglInfo.getTime()) ? new Date().getFullYear().toString() : tglInfo.getFullYear().toString();
      var headerTable = body.appendTable([
        ["PROGRAM", ":", "PENGELOLAAN SUMBER DAYA AIR"],
        ["KEGIATAN", ":", "PENGELOLAAN SDA DAN BANGUNAN PENGAMAN PANTAI PADA WILAYAH SUNGAI (WS) DALAM 1 (SATU) DAERAH KABUPATEN/KOTA"],
        ["PEKERJAAN", ":", ("NORMALISASI DESA " + sectionInfo.desa + " KECAMATAN " + sectionInfo.kecamatan).toUpperCase()],
        ["TAHUN ANGGARAN", ":", thn],
        ["LOKASI", ":", ("DESA " + sectionInfo.desa + " KECAMATAN " + sectionInfo.kecamatan).toUpperCase()],
        ["TANGGAL", ":", String(sectionInfo.tanggal).toUpperCase()]
      ]);
      headerTable.setBorderWidth(0);
      for (var r = 0; r < headerTable.getNumRows(); r++) {
        headerTable.getRow(r).getCell(0).setWidth(120).editAsText().setBold(true).setFontFamily("Arial");
        headerTable.getRow(r).getCell(1).setWidth(15).editAsText().setFontFamily("Arial");
        headerTable.getRow(r).getCell(2).editAsText().setFontFamily("Arial");
      }
      body.appendParagraph("");
    }
    for (var pi = 0; pi < photoBatch.length; pi++) {
      var item = photoBatch[pi];
      try {
        var imgBlob = DriveApp.getFileById(item.imgId).getBlob();
        var tbl = body.appendTable([["", ""]]);
        tbl.setBorderWidth(1);
        var cellImg = tbl.getCell(0, 0);
        cellImg.setWidth(350);
        var inlineImg = cellImg.insertParagraph(0, "").appendInlineImage(imgBlob);
        var origW = inlineImg.getWidth();
        var origH = inlineImg.getHeight();
        var ratio = Math.min(320 / origW, 200 / origH);
        inlineImg.setWidth(origW * ratio).setHeight(origH * ratio);
        var cellDesc = tbl.getCell(0, 1);
        var dt = "KETERANGAN :\n";
        if (item.progress) dt += "FOTO PROSES PELAKSANAAN " + item.progress;
        cellDesc.setText(dt);
        cellDesc.editAsText().setFontFamily("Arial").setBold(0, 12, true);
      } catch (photoErr) {
        console.log("appendDokumentasiPhotos gagal foto index " + pi + ": " + photoErr.message);
      }
    }
    body.appendPageBreak();
    doc.saveAndClose();
    return { success: true };
  } catch (e) { return { success: false, error: e.message }; }
}

function finalizeAndSaveDokumentasi(docId, repInfo) {
  try {
    var doc = DocumentApp.openById(docId);
    var docBlob = doc.getAs("application/pdf");
    var tglInfo = new Date(repInfo.tanggal);
    var thn = isNaN(tglInfo.getTime()) ? new Date().getFullYear().toString() : tglInfo.getFullYear().toString();
    var root = DriveApp.getFolderById(CONFIG.ROOT_FOLDER_PDF);
    var flTahun = getOrCreateFolder(root, thn);
