function appendHourmeterPhotos(docId, hmBatch) {
  try {
    var doc = DocumentApp.openById(docId);
    var body = doc.getBody();
    var tables = body.getTables();
    var tbl = tables[tables.length - 1];
    var offsetIdx = Math.floor(tbl.getNumRows() / 2) + 1;
    for (var hi = 0; hi < hmBatch.length; hi++) {
      var item = hmBatch[hi];
      var num = offsetIdx + hi;
      var rHead = tbl.appendTableRow();
      rHead.appendTableCell(num + ".    " + String(item.tanggal).toUpperCase());
      rHead.appendTableCell("");
      var rImg = tbl.appendTableRow();
      var cBefore = rImg.appendTableCell("");
      var cAfter = rImg.appendTableCell("");
      cBefore.getChild(0).asParagraph().setAlignment(DocumentApp.HorizontalAlignment.CENTER);
      cAfter.getChild(0).asParagraph().setAlignment(DocumentApp.HorizontalAlignment.CENTER);
      try {
        var imgBf = DriveApp.getFileById(item.before).getBlob();
        var parBf = cBefore.getChild(0).asParagraph();
        var inlineBf = parBf.appendInlineImage(imgBf);
        var rw1 = inlineBf.getWidth();
        var rh1 = inlineBf.getHeight();
        inlineBf.setWidth(rw1 * Math.min(200 / rw1, 150 / rh1)).setHeight(rh1 * Math.min(200 / rw1, 150 / rh1));
      } catch (e1) {}
      try {
        var imgAf = DriveApp.getFileById(item.after).getBlob();
        var parAf = cAfter.getChild(0).asParagraph();
        var inlineAf = parAf.appendInlineImage(imgAf);
        var rw2 = inlineAf.getWidth();
        var rh2 = inlineAf.getHeight();
        inlineAf.setWidth(rw2 * Math.min(200 / rw2, 150 / rh2)).setHeight(rh2 * Math.min(200 / rw2, 150 / rh2));
      } catch (e2) {}
    }
    doc.saveAndClose();
    return { success: true };
  } catch (e) { return { success: false, error: e.message }; }
}

