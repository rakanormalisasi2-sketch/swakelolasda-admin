function processSingleRowAsPDF(rowNum) {
  try {
    var ss = SpreadsheetApp.openById(CONFIG.SS_RESP_ID);
    var sheet = ss.getSheetByName(CONFIG.SHEET_RESPONSES);
    var headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
    var row = sheet.getRange(rowNum, 1, 1, sheet.getLastColumn()).getValues()[0];
    if (!row[0]) throw new Error("Baris Kosong");

    var templateFile = DriveApp.getFileById(CONFIG.TEMPLATE_PDF_ID);
    var rootFolder = DriveApp.getFolderById(CONFIG.ROOT_FOLDER_PDF);
    var getCol = function (name) {
      var idx = -1;
      for (var i = 0; i < headers.length; i++) {
        if (headers[i].toLowerCase().indexOf(name.toLowerCase()) !== -1) { idx = i; break; }
      }
      return idx >= 0 ? row[idx] : "";
    };
    var tanggal = getCol("Tanggal Laporan");
    var operator = getCol("Nama Operator") || getCol("Operator");
    var kec = getCol("Kecamatan");
    var desa = getCol("Desa");
    var alat = getCol("Alat");
    var year = (tanggal instanceof Date && !isNaN(tanggal)) ? tanggal.getFullYear().toString() : new Date().getFullYear().toString();

    var yearFolder = getOrCreateFolder(rootFolder, year);
    var kecFolder = getOrCreateFolder(yearFolder, kec.toUpperCase());
    var desaFolder = getOrCreateFolder(kecFolder, desa.toUpperCase());
    var alatFolder = getOrCreateFolder(desaFolder, alat.toUpperCase());
    var operatorFolder = getOrCreateFolder(alatFolder, operator.toUpperCase());
    var targetFolder = getOrCreateFolder(operatorFolder, "HARIAN");
    var copy = templateFile.makeCopy();
    var doc = DocumentApp.openById(copy.getId());
    var body = doc.getBody();

    var specialPlaceholders = {
      "<<TANGGAL_LAPORAN>>": String(row[1] instanceof Date ? formatDateIndo(row[1]) : (row[1] || "")),
      "<<NAMA_OPERATOR>>": String(row[2] || "").toUpperCase(),
      "<<PILIH_KECAMATAN>>": String(row[3] || "").toUpperCase(),
      "<<DESA>>": String(row[4] || "").toUpperCase(),
      "<<JENIS_ALAT_BERAT>>": String(row[5] || "").toUpperCase(),
      "<<PROGRESS_PEKERJAAN>>": String(row[6] || "").toUpperCase(),
      "<<FOTO_LAPANGAN>>": String(row[7] || ""),
      "<<KETERANGAN_TAMBAHAN>>": String(row[8] || ""),
      "<<HOUR_METER_AKHIR>>": String(row[9] || ""),
      "<<PANJANG_PEKERJAAN>>": String(row[10] || ""),
      "<<HOUR_METER_AWAL>>": String(row[11] || ""),
      "<<NAMA_HELPER>>": String(row[12] || "").toUpperCase(),
      "<<JAM_KERJA>>": String(row[13] || "")
    };

    for (var key in specialPlaceholders) {
      try { body.replaceText(key, specialPlaceholders[key]); } catch (e) { console.log("replaceText gagal key " + key + ": " + e.message); }
    }

    for (var i = 0; i < headers.length; i++) {
      var pattern = "<<" + headers[i].toUpperCase().replace(/\s+/g, "_") + ">>";
      var val = row[i];
      if (val instanceof Date) val = formatDateIndo(val);
      try { body.replaceText(pattern, String(val)); } catch (e2) { console.log("replaceText gagal pattern " + pattern + ": " + e2.message); }
    }

    doc.saveAndClose();
    var pdfName = "Laporan_" + operator + "_" + formatDateForFile(tanggal);
    targetFolder.createFile(copy.getAs("application/pdf")).setName(pdfName);
    copy.setTrashed(true);
    return { success: true, url: targetFolder.getUrl(), pdfName: pdfName };
  } catch (e) {
    return { success: false, error: e.message };
  }
}

function processRekapMingguanBackend(indices) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet() || SpreadsheetApp.openById(CONFIG.SS_RESP_ID);
    var sheet = ss.getSheetByName(CONFIG.SHEET_RESPONSES);
    var data = sheet.getDataRange().getValues();
    var rows = [];
    for (var ii = 0; ii < indices.length; ii++) {
      if (indices[ii] - 1 < data.length) rows.push(data[indices[ii] - 1]);
    }
    if (rows.length === 0) return { success: false, error: "Tidak ada baris valid." };

    var groups = {};
    for (var ri = 0; ri < rows.length; ri++) {
      var r = rows[ri];
      var tgl = new Date(r[1]);
      if (isNaN(tgl.getTime())) tgl = new Date();
      var operator = String(r[2] || "").toUpperCase();
      var alat = String(r[5] || "").toUpperCase();
      var weekKey = getISOWeekString(tgl) + "|" + operator + "|" + alat;
      if (!groups[weekKey]) {
        groups[weekKey] = { operator: r[2], kec: r[3], desa: r[4], alat: r[5], rows: [], startDate: tgl };
      }
      groups[weekKey].rows.push(r);
      if (tgl < groups[weekKey].startDate) groups[weekKey].startDate = tgl;
    }

    var template = DriveApp.getFileById(CONFIG.TEMPLATE_REKAP_ID);
    var root = DriveApp.getFolderById(CONFIG.ROOT_FOLDER_PDF);
    var count = 0, mainTargetFolder = null;
    var groupKeys = Object.keys(groups);

    for (var gi = 0; gi < groupKeys.length; gi++) {
      var group = groups[groupKeys[gi]];
      var copy = template.makeCopy("REKAP_TEMP", root);
      var ssCopy = SpreadsheetApp.openById(copy.getId());
      var shCopy = ssCopy.getSheets()[0];
      shCopy.getRange("D4").setValue("DESA " + String(group.desa).toUpperCase() + " KECAMATAN " + String(group.kec).toUpperCase());
      shCopy.getRange("K2").setValue(String(group.alat).toUpperCase());
      group.rows.sort(function (a, b) { return new Date(a[1]) - new Date(b[1]); });

      var startRow = 8;
      for (var ri2 = 0; ri2 < group.rows.length; ri2++) {
        var r2 = group.rows[ri2];
        var d = new Date(r2[1]);
        var strHari = !isNaN(d.getTime()) ? getHariIndo(d) : String(r2[1] || "");
        var strTgl = !isNaN(d.getTime()) ? formatDateIndo(d) : String(r2[1] || "");
        shCopy.getRange(startRow + ri2, 1).setValue(ri2 + 1);
        shCopy.getRange(startRow + ri2, 2).setValue(strHari);
        shCopy.getRange(startRow + ri2, 3).setValue(strTgl);
        shCopy.getRange(startRow + ri2, 4).setValue(r2[2]);
        shCopy.getRange(startRow + ri2, 5).setValue(r2[12]);
        shCopy.getRange(startRow + ri2, 6).setValue(String(r2[4] || "").toUpperCase());
        shCopy.getRange(startRow + ri2, 7).setValue(r2[11]);
        shCopy.getRange(startRow + ri2, 8).setValue(r2[9]);
        var keterangan = r2[8] || "";
        if (r2[13]) keterangan += " (J.Kerja: " + r2[13] + ")";
        shCopy.getRange(startRow + ri2, 9).setValue(keterangan);
      }

      SpreadsheetApp.flush();
      Utilities.sleep(500);
      var url = "https://docs.google.com/spreadsheets/d/" + copy.getId() + "/export?format=pdf&portrait=false&fitw=true";
      var pdfBlob = UrlFetchApp.fetch(url, { headers: { "Authorization": "Bearer " + ScriptApp.getOAuthToken() } }).getBlob();
      var yearFolder = getOrCreateFolder(root, group.startDate.getFullYear().toString());
      var kecF = getOrCreateFolder(yearFolder, String(group.kec).toUpperCase());
      var desaF = getOrCreateFolder(kecF, String(group.desa).toUpperCase());
      var alatF = getOrCreateFolder(desaF, String(group.alat).toUpperCase());
      var opF = getOrCreateFolder(alatF, String(group.operator).toUpperCase());
      var targetFolder = getOrCreateFolder(opF, "MINGGUAN");
      if (!mainTargetFolder) mainTargetFolder = targetFolder;
      var finalName = "Rekap_Minggu_" + String(group.desa) + "_" + String(group.operator) + "_" + formatDateForFile(group.startDate);
      targetFolder.createFile(pdfBlob).setName(finalName);
      copy.setTrashed(true);
      count++;
    }
    return { success: true, url: mainTargetFolder.getUrl(), count: count };
  } catch (e) { return { success: false, error: e.message }; }
}

function getISOWeekString(date) {
  var d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  var dayNum = d.getUTCDay() || 7;
  d.setUTCDate(d.getUTCDate() + 4 - dayNum);
  var yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
  var weekNo = Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
  return d.getUTCFullYear() + "-W" + (weekNo < 10 ? "0" : "") + weekNo;
}

function getOrCreateFolder(parent, name) {
  var folders = parent.getFoldersByName(name);
  return folders.hasNext() ? folders.next() : parent.createFolder(name);
}

function sanitizeName(t) {
  return String(t || "UNKNOWN").replace(/[\/\\:*?"<>|]/g, "").trim();
}

function formatDateForFile(d) {
  return (d instanceof Date) ? Utilities.formatDate(d, Session.getScriptTimeZone(), "yyyy-MM-dd") : "";
}

function getHariIndo(d) {
  var days = ["Minggu", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu"];
  return days[d.getDay()];
}

function formatDateIndo(d) {
  var m = ["Jan","Feb","Mar","Apr","Mei","Jun","Jul","Agu","Sep","Okt","Nov","Des"];
  return (d instanceof Date) ? d.getDate() + " " + m[d.getMonth()] + " " + d.getFullYear() : d;
}

