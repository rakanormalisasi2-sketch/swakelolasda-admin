function getPhotoThumbnails(fileIds) {
  var result = {};
  for (var i = 0; i < fileIds.length; i++) {
    var fid = fileIds[i];
    try {
      var file = DriveApp.getFileById(fid);
      var blob = file.getBlob();
      var contentType = blob.getContentType() || "image/jpeg";
      var bytes = blob.getBytes();
      if (bytes.length > 500000) {
        try {
          var thumbBlob = file.getThumbnail();
          if (thumbBlob) {
            contentType = thumbBlob.getContentType() || "image/png";
            bytes = thumbBlob.getBytes();
          }
        } catch (te) {}
      }
      var b64 = Utilities.base64Encode(bytes);
      result[fid] = "data:" + contentType + ";base64," + b64;
    } catch (e) {
      result[fid] = "ERROR:" + e.message;
    }
  }
  return result;
}

