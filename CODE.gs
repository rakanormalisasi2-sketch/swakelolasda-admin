function organizeSpreadsheetData() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet() || SpreadsheetApp.openById(CONFIG.SS_RESP_ID);
    var sheet = ss.getSheetByName(CONFIG.SHEET_RESPONSES);
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return;
    var bodyData = data.slice(1);

    function parseDateSafe(val) {
      var d = new Date(val);
      return (Object.prototype.toString.call(val) === "[object Date]" && !isNaN(val.getTime())) ? val : (isNaN(d.getTime()) ? null : d);
    }

    bodyData.sort(function (a, b) {
      var dateA = parseDateSafe(a[1]), dateB = parseDateSafe(b[1]);
      var yearA = dateA ? dateA.getFullYear() : 0, yearB = dateB ? dateB.getFullYear() : 0;
      if (yearA !== yearB) return yearA - yearB;
      var bufA = [a[3] || "", a[4] || "", a[5] || "", a[2] || ""];
      var bufB = [b[3] || "", b[4] || "", b[5] || "", b[2] || ""];
      for (var j = 0; j < 4; j++) {
        var cmp = String(bufA[j]).localeCompare(String(bufB[j]));
        if (cmp !== 0) return cmp;
      }
      return ((dateA === null && dateB === null) ? 0 : (dateA === null ? 1 : (dateB === null ? -1 : dateA - dateB)));
    });

    sheet.getRange(2, 1, bodyData.length, bodyData[0].length).setValues(bodyData);
    sheet.getRange(2, 1, bodyData.length, 15).setBackground(null);

    var colorPool = ["#FFB3BA","#FFDFBA","#FFFFBA","#BAFFC9","#BAE1FF","#E6B3FF","#FFD6E8","#D5FFCC","#CCE5FF","#FFF2CC"];
    var currentKey = "", colorIndex = 0;
    for (var i = 0; i < bodyData.length; i++) {
      var dateD = parseDateSafe(bodyData[i][1]);
      var yr = dateD ? dateD.getFullYear() : 0;
      var key = yr + "|" + bodyData[i][3] + "|" + bodyData[i][4] + "|" + bodyData[i][5] + "|" + bodyData[i][2];
      if (key !== currentKey) {
        if (colorIndex >= colorPool.length) colorIndex = 0;
        currentKey = key;
        colorIndex++;
      }
      sheet.getRange(2 + i, 1, 1, 15).setBackground(colorPool[(colorIndex - 1) % colorPool.length]);
    }
  } catch (e) {
    console.log("organizeSpreadsheetData gagal: " + e.message);
  }
}

function extractFotoUrlsFromCell(cellValue) {
  var raw = (cellValue || "").toString().trim();
  if (!raw) return [];
  var folderMatch = raw.match(/drive\.google\.com\/drive\/folders\/([a-zA-Z0-9_-]+)/);
  if (!folderMatch) folderMatch = raw.match(/folders\/([a-zA-Z0-9_-]+)/);
  if (folderMatch) {
    var urls = [];
    try {
      var folder = DriveApp.getFolderById(folderMatch[1]);
      var files = folder.getFiles();
      while (files.hasNext()) {
        var f = files.next();
        if ((f.getMimeType() || "").indexOf("image") !== -1) {
          urls.push("https://drive.google.com/file/d/" + f.getId() + "/view");
        }
      }
    } catch (e) {
      console.log("extractFotoUrlsFromCell gagal akses folder: " + e.message);
    }
    return urls;
  }
  return raw.split(",").map(function (l) { return l.trim(); }).filter(function (l) {
    return l.match(/[-\w]{25,}/) && l.indexOf("/folders/") === -1;
  });
}

