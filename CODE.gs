    var map = {};
    var lastKec = "";
    for (var i = 0; i < data.length; i++) {
      var kec = String(data[i][0] || "").trim().toUpperCase();
      var desa = String(data[i][1] || "").trim();
      if (kec) lastKec = kec;
      if (!lastKec || !desa) continue;
