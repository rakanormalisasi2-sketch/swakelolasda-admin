function ORG_processRow(row, rowIndex, sheet) {
  var tanggalLaporan = new Date(row[1]);
  if (!row[7] || isNaN(tanggalLaporan.getTime())) return;
  try {
    var root = DriveApp.getFolderById(CONFIG.ORG_ROOT_DEST_FOLDER_ID);
    var tahunFolder = getOrCreateFolder(root, tanggalLaporan.getFullYear().toString());
    var kecFolder = getOrCreateFolder(tahunFolder, sanitizeName(row[3]));
    var desaFolder = getOrCreateFolder(kecFolder, sanitizeName(row[4]));
    var alatFolder = getOrCreateFolder(desaFolder, sanitizeName(row[5]));
    var operatorFolder = getOrCreateFolder(alatFolder, sanitizeName(row[2]));
    var tanggalFolder = getOrCreateFolder(operatorFolder, Utilities.formatDate(tanggalLaporan, Session.getScriptTimeZone(), "yyyy-MM-dd"));
    var links = row[7].split(",").map(function (l) { return l.trim(); }).filter(function (l) { return l !== ""; });
    for (var i = 0; i < links.length; i++) {
      try {
        var match = links[i].match(/[-\w]{25,}/);
        if (!match) continue;
        var file = DriveApp.getFileById(match[0]);
        tanggalFolder.addFile(file);
        var parents = file.getParents();
        while (parents.hasNext()) {
          var parent = parents.next();
          if (parent.getId() !== tanggalFolder.getId()) parent.removeFile(file);
        }
      } catch (innerErr) {
        console.log("ORG_processRow - gagal proses link foto index " + i + ": " + innerErr.message);
      }
    }
    sheet.getRange(rowIndex, 8).setValue(tanggalFolder.getUrl());
  } catch (e) {
    console.log("ORG_processRow gagal: " + e.message);
  }
}

